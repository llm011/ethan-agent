# Ethan Agent - 绿联 NAS 环境变量
# 复制为 .env 后填入实际值。这个文件含密钥，不要上传 git。

# ── LLM Provider（用你的 new-api 网关）──────────────────────
# yuntoken 网关，OpenAI 兼容格式
ANTHROPIC_AUTH_TOKEN=sk-YOUR_API_KEY_HERE
ANTHROPIC_BASE_URL=https://yuntoken.vip/

# ── 默认模型 ─────────────────────────────────────────────
# 注意：new-api 网关上 claude-opus-4.8 配额满、claude-sonnet-4.6 要 profileArn
# 目前实测可用的是 claude-haiku-4.5，建议先用它
AGENT_DEFAULT_MODEL=claude-haiku-4.5

# ── Web UI 登录 Token ────────────────────────────────────
# 局域网用，自己设一个登录密码。访问 http://10.0.0.75:8900 时输入
ETHAN_AUTH_TOKEN=改成你自己的密码

# ── 代理（关键！）────────────────────────────────────────
# NAS 上有代理 10.0.0.75:7890（HTTP），容器用这个出外网
# ⚠️ 注意：容器内 127.0.0.1 指容器自己，不是 NAS。必须用宿主机地址：
#   - 10.0.0.75（NAS 局域网 IP，最稳）
#   - 或 host.docker.internal（Docker 内置的宿主机别名，部分版本支持）
ETHAN_PROXY=http://10.0.0.75:7890
