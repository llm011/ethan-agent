# Ethan Agent — Docker 环境变量配置
# 复制此文件为 .env 并填入实际值

# ── Provider 配置（至少填一个）──────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# 三方中转地址（可选，不填则用官方 api.anthropic.com）
ANTHROPIC_BASE_URL=

# OpenAI 兼容 API（GPT / Gemini / Ollama / OpenRouter 等）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── 默认模型 ─────────────────────────────────────────────
# 可选值：claude-sonnet-4-6、claude-opus-4-6、gemini-2.5-flash 等
AGENT_DEFAULT_MODEL=claude-sonnet-4-6

# ── Web UI 鉴权 Token ──────────────────────────────────────
# 留空则不鉴权（局域网内部署可留空）
ETHAN_AUTH_TOKEN=

# ── 代理（可选）─────────────────────────────────────────
ETHAN_PROXY=

# ── SearXNG Web 搜索（可选）───────────────────────────────
# 给 web_search 工具接一个 SearXNG 实例，免费、无 API Key、隐私友好。
# 留空则 web_search 默认走 DuckDuckGo。
#
# 方式一：自建（配合根目录的 docker-compose.searxng.yml 一起 up）
#   docker compose -f docker-compose.searxng.yml up -d
#   然后填：SEARXNG_BASE_URL=http://searxng:8080   （容器间用服务名互联）
#
# 方式二：已有现成 SearXNG 实例（自建别处或第三方）
#   直接填该实例地址，如：SEARXNG_BASE_URL=https://searx.example.com
SEARXNG_BASE_URL=
