# Ethan Agent — Docker 环境变量配置
# 复制此文件为 .env 并填入实际值

# ── Provider 配置（至少填一个）──────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# 三方中转地址（可选，不填则用官方 api.anthropic.com）
ANTHROPIC_BASE_URL=

# OpenAI 兼容 API（GPT / Gemini / Ollama / OpenRouter 等）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── 默认模型 ─────────────────────────────────────────────
# 可选值：claude-sonnet-4-6、claude-opus-4-6、gemini-2.5-flash 等
AGENT_DEFAULT_MODEL=claude-sonnet-4-6

# ── Web UI 鉴权 Token ──────────────────────────────────────
# 留空则不鉴权（局域网内部署可留空）
ETHAN_AUTH_TOKEN=

# ── 代理（可选）─────────────────────────────────────────
ETHAN_PROXY=
