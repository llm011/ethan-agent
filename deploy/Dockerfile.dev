# Ethan Agent — 开发/调试镜像（含 Web UI）
# 在正式镜像基础上增加常用工具（vim、less、ll 等）

# ── Stage 1: 构建 Web UI ──────────────────────────────────────
FROM node:20-alpine AS web-builder

WORKDIR /web
COPY web/package.json web/pnpm-lock.yaml ./
RUN npm install -g pnpm && pnpm install --frozen-lockfile

COPY web/ .
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_OUTPUT=export
RUN pnpm run build

# ── Stage 2: Python + 调试工具 ────────────────────────────────
FROM python:3.12-slim

WORKDIR /app

# 系统依赖 + 开发调试工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc make \
    ripgrep fd-find \
    curl git ca-certificates \
    vim-tiny less tree bat \
    jq wget unzip \
    && ln -s /usr/bin/fdfind /usr/local/bin/fd \
    && ln -s /usr/bin/batcat /usr/local/bin/bat \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI（gh）：官方 apt 仓库，自动适配架构（amd64/arm64）
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# shell 便利设置：ll / la / cat 高亮
RUN echo 'alias ll="ls -alF --color=auto"' >> /root/.bashrc \
    && echo 'alias la="ls -A --color=auto"' >> /root/.bashrc \
    && echo 'alias vi="vim.tiny"' >> /root/.bashrc \
    && echo 'alias vim="vim.tiny"' >> /root/.bashrc \
    && echo 'alias cat="bat --plain --paging=never 2>/dev/null || command cat"' >> /root/.bashrc \
    && echo 'export PS1="\[\e[36m\]ethan-dev\[\e[0m\]:\w# "' >> /root/.bashrc

# 安装 uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# 先复制依赖文件，利用 Docker 层缓存
COPY pyproject.toml uv.lock ./

# 安装 Python 依赖（不安装项目本身）
RUN uv sync --frozen --no-dev --no-install-project

# 复制源码和元数据文件
COPY ethan/ ./ethan/
COPY README.md README_CN.md ./

# 从 Stage 1 拷入 Web UI 静态产物
COPY --from=web-builder /web/out ./ethan/web_dist

# 安装项目本身
RUN uv sync --frozen --no-dev

VOLUME /root/.ethan
EXPOSE 8900

CMD ["bash"]
