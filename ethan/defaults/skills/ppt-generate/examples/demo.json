    {
      "id": "content-formula",
      "type": "content",
      "remark": "召回率是 ANN 索引调参的核心指标：相对暴力精确检索的 top-K 重合度。",
      "elements": [
        { "id": "title", "type": "text", "left": 60, "top": 36, "width": 880, "height": 56, "textType": "title",
          "paragraphs": [ { "runs": [ { "text": "召回率怎么衡量：Recall@K", "bold": true, "fontSize": 26 } ] } ] },
        { "id": "rule", "type": "line", "start": [60, 108], "end": [940, 108], "width": 1.5, "style": "solid", "color": "#E5E7EB", "points": ["", ""] },
        { "id": "formula", "type": "latex", "left": 100, "top": 160, "width": 800, "height": 110,
          "latex": "\\mathrm{Recall@K} = \\frac{|\\,S_K(q) \\cap S_K^{*}(q)\\,|}{K}",
          "fontSize": 30, "color": "#111827", "align": "center" },
        { "id": "legend", "type": "text", "left": 150, "top": 285, "width": 700, "height": 60, "textType": "content",
          "paragraphs": [
            { "lineHeight": 1.6, "runs": [ { "text": "S_K(q)：ANN 索引返回的 top-K；", "fontSize": 14 }, { "text": "S_K*(q)：暴力精确检索的 top-K（ground truth）", "fontSize": 14, "bold": true } ] }
          ] },
        { "id": "explain", "type": "text", "left": 150, "top": 350, "width": 700, "height": 130, "textType": "content",
          "paragraphs": [
            { "lineHeight": 1.6, "bullet": "bullet", "runs": [ { "text": "离线调参看 Recall@K，线上效果看 nDCG，两者要一起看", "fontSize": 14 } ] },
            { "lineHeight": 1.6, "bullet": "bullet", "runs": [ { "text": "K 通常取 10/100，与业务召回阶段截断一致", "fontSize": 14 } ] },
            { "lineHeight": 1.6, "bullet": "bullet", "runs": [ { "text": "评测集要覆盖长尾 query，否则召回率虚高", "fontSize": 14 } ] }
          ] }
      ]
    },
    {
      "id": "content-ivfflat",
      "type": "content",
      "remark": "IVFFlat 的核心 trade-off：nprobe 越大召回越高、延迟越大。flat 表示不重排量化，精度无损。",
      "elements": [
        { "id": "title", "type": "text", "left": 60, "top": 36, "width": 880, "height": 56, "textType": "title",
          "paragraphs": [ { "runs": [ { "text": "IVFFlat：用聚类剪枝换检索速度", "bold": true, "fontSize": 26 } ] } ] },
        { "id": "rule", "type": "line", "start": [60, 108], "end": [940, 108], "width": 1.5, "style": "solid", "color": "#E5E7EB", "points": ["", ""] },
        { "id": "step1", "type": "text", "left": 60, "top": 126, "width": 520, "height": 24, "textType": "itemTitle",
          "paragraphs": [ { "runs": [ { "text": "① 建索引：k-means 把向量空间切成 L 个簇", "bold": true, "fontSize": 15, "color": "#1E40AF" } ] } ] },
        { "id": "formula1", "type": "latex", "left": 60, "top": 156, "width": 520, "height": 90,
          "latex": "\\min_{c_1, \\dots, c_L} \\sum_{x \\in \\mathcal{X}} \\min_{1 \\le j \\le L} \\| x - c_j \\|_2^2",
          "fontSize": 20, "color": "#111827", "align": "center" },
        { "id": "step2", "type": "text", "left": 60, "top": 258, "width": 520, "height": 24, "textType": "itemTitle",
          "paragraphs": [ { "runs": [ { "text": "② 查询：只扫描最近的 P 个簇（nprobe = P）", "bold": true, "fontSize": 15, "color": "#1E40AF" } ] } ] },
        { "id": "formula2", "type": "latex", "left": 60, "top": 288, "width": 520, "height": 90,
          "latex": "\\hat{S}(q) = \\bigcup_{j \\in \\mathrm{top}_{P}(q)} L_j, \\quad \\mathrm{top}_{P}(q) = \\underset{j \\in [L]}{\\mathrm{argmin}_{P}} \\; \\| q - c_j \\|_2",
          "fontSize": 18, "color": "#111827", "align": "center" },
        { "id": "side", "type": "shape", "left": 620, "top": 126, "width": 320, "height": 252, "shape": "roundRect", "fill": "#EFF6FF" },
        { "id": "side-title", "type": "text", "left": 644, "top": 142, "width": 272, "height": 26, "textType": "itemTitle",
          "paragraphs": [ { "runs": [ { "text": "工程要点", "bold": true, "fontSize": 16, "color": "#1E40AF" } ] } ] },
        { "id": "side-body", "type": "text", "left": 644, "top": 176, "width": 272, "height": 190, "textType": "item",
          "paragraphs": [
            { "lineHeight": 1.55, "bullet": "bullet", "runs": [ { "text": "nlist = L 常取 √N 量级", "fontSize": 13 } ] },
            { "lineHeight": 1.55, "bullet": "bullet", "runs": [ { "text": "nprobe 是召回/延迟旋钮", "fontSize": 13 } ] },
            { "lineHeight": 1.55, "bullet": "bullet", "runs": [ { "text": "Flat 不量化，距离无损", "fontSize": 13 } ] },
            { "lineHeight": 1.55, "bullet": "bullet", "runs": [ { "text": "内存友好度不如 IVF-PQ", "fontSize": 13 } ] }
          ] },
        { "id": "tbl", "type": "table", "left": 60, "top": 396, "width": 520, "height": 130, "colWidths": [0.34, 0.33, 0.33], "cellMinHeight": 32,
          "outline": { "style": "solid", "width": 1, "color": "#E5E7EB" },
          "theme": { "color": "#1E40AF", "rowHeader": true, "rowFooter": false, "colHeader": false, "colFooter": false },
          "data": [
            [ { "text": "nprobe" }, { "text": "Recall@10" }, { "text": "P99 延迟" } ],
            [ { "text": "8" }, { "text": "0.86" }, { "text": "6ms" } ],
            [ { "text": "64" }, { "text": "0.97" }, { "text": "21ms" } ]
          ] },
        { "id": "src", "type": "text", "left": 620, "top": 505, "width": 320, "height": 18, "textType": "notes",
          "paragraphs": [ { "runs": [ { "text": "数据为 1M 向量上的示例值", "fontSize": 10, "color": "#9CA3AF" } ] } ] }
