{
  "manifest_version": 3,
  "name": "Ethan Browser",
  "version": "0.5.0",
  "description": "Bridge Ethan agent browser commands to Chrome tabs over WebSocket. v0.5.0 (offscreen)",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Ethan Browser",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "debugger",
    "storage",
    "tabGroups",
    "tabs",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "ws://localhost/*",
    "ws://127.0.0.1/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ]
}
