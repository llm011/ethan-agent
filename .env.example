# Ethan Agent — Environment Variables
# Copy this file to .env and fill in your values.
# These override ~/.ethan/config.yaml provider settings.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_AUTH_TOKEN=sk-xxx        # alternative key field
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible (GPT, Gemini, Ollama, OpenRouter, etc.)
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# Agent defaults
# AGENT_DEFAULT_MODEL=claude-sonnet-4-6

# Global proxy (optional)
# ETHAN_PROXY=http://127.0.0.1:7890
